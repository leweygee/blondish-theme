{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,

  "settings": {

    "appearanceTools": true,

    "color": {
      "defaultPalette":   false,
      "defaultGradients": false,
      "custom":           true,
      "customGradient":   false,
      "duotone":          [],
      "palette": [
        { "name": "Black",        "slug": "black",        "color": "#000000" },
        { "name": "White",        "slug": "white",        "color": "#FFFFFF" },
        { "name": "Brand Primary","slug": "brand-primary","color": "#D4A853" },
        { "name": "Brand Accent", "slug": "brand-accent", "color": "#E8C547" },
        { "name": "Dark Grey",    "slug": "dark-grey",    "color": "#333333" },
        { "name": "Light Grey",   "slug": "light-grey",   "color": "#999999" },
        { "name": "Transparent",  "slug": "transparent",  "color": "transparent" }
      ]
    },

    "typography": {
      "fluid":         true,
      "customFontSize": true,
      "fontSizes": [
        { "name": "XS",      "slug": "xs",      "size": "0.75rem",                             "fluid": false },
        { "name": "Small",   "slug": "sm",      "size": "0.875rem",                            "fluid": false },
        { "name": "Base",    "slug": "base",    "size": "1rem",                                "fluid": false },
        { "name": "Medium",  "slug": "md",      "size": "1.125rem",                            "fluid": false },
        { "name": "Large",   "slug": "lg",      "size": "1.5rem",                              "fluid": { "min": "1.25rem", "max": "1.5rem" } },
        { "name": "XL",      "slug": "xl",      "size": "2rem",                                "fluid": { "min": "1.5rem",  "max": "2rem"   } },
        { "name": "2XL",     "slug": "2xl",     "size": "3rem",                                "fluid": { "min": "2rem",    "max": "3rem"   } },
        { "name": "3XL",     "slug": "3xl",     "size": "4.5rem",                              "fluid": { "min": "2.5rem",  "max": "4.5rem" } },
        { "name": "Display", "slug": "display", "size": "clamp(3rem, 8vw, 7rem)",              "fluid": false }
      ],
      "fontFamilies": [
        {
          "name":       "Heading Font",
          "slug":       "heading",
          "fontFamily": "Montserrat, sans-serif",
          "fontFace": [
            {
              "fontFamily":  "Montserrat",
              "fontWeight":  "400",
              "fontStyle":   "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/Montserrat-Regular.woff2" ]
            },
            {
              "fontFamily":  "Montserrat",
              "fontWeight":  "700",
              "fontStyle":   "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/Montserrat-Bold.woff2" ]
            }
          ]
        },
        {
          "name":       "Body Font",
          "slug":       "body",
          "fontFamily": "Inter, sans-serif",
          "fontFace": [
            {
              "fontFamily":  "Inter",
              "fontWeight":  "400",
              "fontStyle":   "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/Inter-Regular.woff2" ]
            },
            {
              "fontFamily":  "Inter",
              "fontWeight":  "600",
              "fontStyle":   "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/Inter-SemiBold.woff2" ]
            }
          ]
        }
      ]
    },

    "spacing": {
      "customSpacingSize": true,
      "units": [ "px", "em", "rem", "vw", "vh", "%" ],
      "spacingSizes": [
        { "name": "XS",  "slug": "xs",  "size": "0.5rem"  },
        { "name": "SM",  "slug": "sm",  "size": "1rem"    },
        { "name": "MD",  "slug": "md",  "size": "1.5rem"  },
        { "name": "LG",  "slug": "lg",  "size": "2.5rem"  },
        { "name": "XL",  "slug": "xl",  "size": "4rem"    },
        { "name": "2XL", "slug": "2xl", "size": "6rem"    },
        { "name": "3XL", "slug": "3xl", "size": "9rem"    }
      ]
    },

    "layout": {
      "contentSize": "720px",
      "wideSize":    "1200px"
    },

    "border": {
      "color":  true,
      "radius": true,
      "style":  true,
      "width":  true
    },

    "blocks": {
      "core/button": {
        "border": { "radius": "0px" }
      },
      "core/image": {
        "lightbox": { "enabled": false }
      },
      "core/navigation": {
        "typography": {
          "customFontSize": true
        }
      }
    }
  },

  "styles": {

    "color": {
      "background": "var(--wp--preset--color--black)",
      "text":       "var(--wp--preset--color--white)"
    },

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize":   "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },

    "spacing": {
      "blockGap": "var(--wp--preset--spacing--md)"
    },

    "elements": {

      "h1": {
        "typography": {
          "fontFamily":    "var(--wp--preset--font-family--heading)",
          "fontSize":      "var(--wp--preset--font-size--display)",
          "fontWeight":    "700",
          "lineHeight":    "1.1",
          "letterSpacing": "-0.02em",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "var(--wp--preset--color--white)"
        }
      },

      "h2": {
        "typography": {
          "fontFamily":    "var(--wp--preset--font-family--heading)",
          "fontSize":      "var(--wp--preset--font-size--2xl)",
          "fontWeight":    "700",
          "lineHeight":    "1.2",
          "letterSpacing": "-0.01em",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "var(--wp--preset--color--white)"
        }
      },

      "h3": {
        "typography": {
          "fontFamily":  "var(--wp--preset--font-family--heading)",
          "fontSize":    "var(--wp--preset--font-size--xl)",
          "fontWeight":  "400",
          "lineHeight":  "1.3"
        }
      },

      "h4": {
        "typography": {
          "fontFamily":  "var(--wp--preset--font-family--heading)",
          "fontSize":    "var(--wp--preset--font-size--lg)",
          "fontWeight":  "700",
          "lineHeight":  "1.4"
        }
      },

      "link": {
        "color": {
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "textDecoration": "none"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--brand-accent)"
          }
        }
      },

      "button": {
        "border": {
          "radius": "0"
        },
        "color": {
          "background": "var(--wp--preset--color--white)",
          "text":       "var(--wp--preset--color--black)"
        },
        "typography": {
          "fontFamily":    "var(--wp--preset--font-family--heading)",
          "fontWeight":    "700",
          "textTransform": "uppercase",
          "letterSpacing": "0.1em",
          "fontSize":      "var(--wp--preset--font-size--sm)"
        },
        "spacing": {
          "padding": {
            "top":    "0.75rem",
            "bottom": "0.75rem",
            "left":   "2rem",
            "right":  "2rem"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--brand-accent)",
            "text":       "var(--wp--preset--color--white)"
          }
        }
      },

      "caption": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xs)"
        },
        "color": {
          "text": "var(--wp--preset--color--light-grey)"
        }
      }

    },

    "blocks": {

      "core/paragraph": {
        "typography": {
          "fontSize":   "var(--wp--preset--font-size--base)",
          "lineHeight": "1.7"
        }
      },

      "core/navigation": {
        "typography": {
          "fontFamily":    "var(--wp--preset--font-family--heading)",
          "fontWeight":    "700",
          "textTransform": "uppercase",
          "letterSpacing": "0.08em",
          "fontSize":      "var(--wp--preset--font-size--sm)"
        },
        "color": {
          "text":       "var(--wp--preset--color--white)",
          "background": "transparent"
        }
      },

      "core/site-title": {
        "typography": {
          "fontFamily":    "var(--wp--preset--font-family--heading)",
          "fontWeight":    "700",
          "textTransform": "uppercase",
          "letterSpacing": "0.1em",
          "fontSize":      "var(--wp--preset--font-size--md)"
        },
        "color": {
          "text": "var(--wp--preset--color--white)"
        }
      },

      "core/post-title": {
        "typography": {
          "fontFamily":    "var(--wp--preset--font-family--heading)",
          "fontSize":      "var(--wp--preset--font-size--3xl)",
          "fontWeight":    "700",
          "lineHeight":    "1.1",
          "letterSpacing": "-0.02em",
          "textTransform": "uppercase"
        }
      },

      "core/separator": {
        "color": {
          "text": "var(--wp--preset--color--dark-grey)"
        },
        "border": {
          "color": "var(--wp--preset--color--dark-grey)",
          "width": "1px"
        }
      }

    }
  },

  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],

  "customTemplates": [
    {
      "name":        "full-bleed-landing",
      "title":       "Full-Bleed Landing",
      "postTypes":   [ "page" ]
    },
    {
      "name":        "standard-content",
      "title":       "Standard Content",
      "postTypes":   [ "page" ]
    },
    {
      "name":        "embed-page",
      "title":       "Embed Page",
      "postTypes":   [ "page" ]
    }
  ]
}
